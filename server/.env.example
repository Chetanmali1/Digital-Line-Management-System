# ============================================
# Digital Queue Management System - Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# ─── Server ──────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MongoDB Atlas ───────────────────────────
# Format: mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your_user:your_password@cluster0.xxxxx.mongodb.net/queue_management?retryWrites=true&w=majority

# ─── JWT ─────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars
JWT_EXPIRES_IN=7d

# ─── Redis ───────────────────────────────────
# Local: redis://localhost:6379
# Redis Cloud: redis://:password@hostname:port
REDIS_URL=redis://localhost:6379

# ─── OpenAI ──────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# ─── Client ──────────────────────────────────
CLIENT_URL=http://localhost:3000

# ─── Logging ─────────────────────────────────
LOG_LEVEL=info
