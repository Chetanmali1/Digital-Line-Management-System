# ============================================================
# Queue Management System - Root Environment Variables
# Used by docker-compose.yml
# ============================================================

# ─── MongoDB (local docker dev) ──────────────────────────
MONGO_USER=admin
MONGO_PASSWORD=queuepassword_change_in_prod

# ─── Redis ───────────────────────────────────────────────
REDIS_PASSWORD=redispassword_change_in_prod

# ─── JWT Secret ──────────────────────────────────────────
# IMPORTANT: Generate a strong secret before deploying!
# Command: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_THIS_WITH_STRONG_SECRET_MINIMUM_32_CHARS

# ─── OpenAI ──────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here

# ─── MongoDB Atlas (for production, overrides docker) ────
# MONGODB_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/queue_management
